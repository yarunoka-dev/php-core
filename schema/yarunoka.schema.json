{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/yarunoka-dev/php-core/schema/v1",
    "title": "Yarunoka schedule document (version 1)",
    "description": "A document of the calendar-aware schedule DSL. This JSON Schema is the authority on the syntax; each language implementation is its mirror. Resolvability of custom references and resolver names, presence of the definitions required by the built-in vocabulary, start < end and non-overlap for time windows, existence of dates and the timezone, from < until, and presence of from in a schedule that uses [\"every\", N, \"day\"] cannot be expressed in the schema, so implementations validate them at parse time (the constraints beyond the schema). Timezones with DST transitions are interpreted per RFC 5545 \u00a73.3.5.",
    "type": "object",
    "additionalProperties": false,
    "required": ["version", "timezone", "schedules"],
    "properties": {
        "version": {"const": 1},
        "timezone": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "definitions": {"$ref": "#/$defs/definitions"},
        "schedules": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "#/$defs/schedule"}
        }
    },
    "$defs": {
        "definitions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "holidays": {"$ref": "#/$defs/dateSet"},
                "business_holidays": {"$ref": "#/$defs/dateSet"},
                "business_days": {"$ref": "#/$defs/dateSet"},
                "workweek": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {"$ref": "#/$defs/dayName"}
                },
                "business_hours": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {"$ref": "#/$defs/window"}
                },
                "custom": {
                    "type": "object",
                    "propertyNames": {"$ref": "#/$defs/customName"},
                    "additionalProperties": {"$ref": "#/$defs/dateSet"}
                }
            }
        },

        "date": {"type": "string", "minLength": 10, "maxLength": 10, "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "resolverName": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S",
            "not": {"pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
        },
        "dateSet": {
            "oneOf": [
                {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/date"}},
                {"$ref": "#/$defs/resolverName"}
            ]
        },

        "customName": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S",
            "allOf": [
                {"not": {"enum": [
                    "weekday", "weekend", "holiday", "business_day", "business_holiday", "business_hour",
                    "mon", "tue", "wed", "thu", "fri", "sat", "sun",
                    "1st", "2nd", "3rd", "4th", "5th", "last",
                    "last_day_of_month",
                    "not", "prev", "next", "or_same",
                    "hour", "minute", "second", "day",
                    "version", "timezone", "definitions", "schedules",
                    "years", "months", "days", "shift", "if", "times", "allday", "every", "between", "from", "until",
                    "holidays", "business_holidays", "business_days", "workweek", "business_hours", "custom"
                ]}},
                {"not": {"pattern": "^\\d+$"}},
                {"not": {"pattern": "^\\d{2}:\\d{2}$"}},
                {"not": {"pattern": "^\\d{4}-\\d{2}-\\d{2}$"}}
            ]
        },

        "schedule": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "from": {"$ref": "#/$defs/dateTime"},
                "until": {"$ref": "#/$defs/dateTime"},
                "years": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {"type": "integer", "minimum": 1, "maximum": 9999}
                },
                "months": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {"type": "integer", "minimum": 1, "maximum": 12}
                },
                "days": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {"oneOf": [
                        {"$ref": "#/$defs/dayAtom"},
                        {"$ref": "#/$defs/dayCycle"}
                    ]}
                },
                "shift": {"$ref": "#/$defs/shift"},
                "if": {"$ref": "#/$defs/ifGuard"},
                "times": {"$ref": "#/$defs/times"},
                "allday": {"const": true},
                "every": {"$ref": "#/$defs/sequenceEvery"}
            },
            "oneOf": [
                {
                    "required": ["times"],
                    "not": {"anyOf": [{"required": ["allday"]}, {"required": ["every"]}]}
                },
                {
                    "required": ["allday"],
                    "not": {"anyOf": [{"required": ["times"]}, {"required": ["every"]}]}
                },
                {
                    "required": ["every", "from"],
                    "not": {"anyOf": [
                        {"required": ["times"]}, {"required": ["allday"]},
                        {"required": ["years"]}, {"required": ["months"]}, {"required": ["days"]},
                        {"required": ["shift"]}, {"required": ["if"]}
                    ]}
                }
            ]
        },

        "dateTime": {
            "type": "string",
            "minLength": 16,
            "maxLength": 16,
            "pattern": "^\\d{4}-\\d{2}-\\d{2} ([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "dayCycle": {
            "type": "array",
            "prefixItems": [
                {"const": "every"},
                {"type": "integer", "minimum": 1},
                {"const": "day"}
            ],
            "minItems": 3,
            "maxItems": 3,
            "items": false
        },
        "sequenceEvery": {
            "type": "array",
            "prefixItems": [
                {"type": "integer", "minimum": 1},
                {"enum": ["hour", "minute", "second"]}
            ],
            "minItems": 2,
            "maxItems": 2,
            "items": false
        },

        "dayName": {"enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]},
        "ordinal": {"enum": ["1st", "2nd", "3rd", "4th", "5th", "last"]},
        "ordinalTuple": {
            "type": "array",
            "prefixItems": [{"$ref": "#/$defs/ordinal"}, {"$ref": "#/$defs/dayName"}],
            "minItems": 2,
            "maxItems": 2,
            "items": false
        },
        "dayAtomWord": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S",
            "allOf": [
                {"not": {"enum": [
                    "business_hour",
                    "1st", "2nd", "3rd", "4th", "5th", "last",
                    "not", "prev", "next", "or_same",
                    "hour", "minute", "second", "day",
                    "version", "timezone", "definitions", "schedules",
                    "years", "months", "days", "shift", "if", "times", "allday", "every", "between", "from", "until",
                    "holidays", "business_holidays", "business_days", "workweek", "business_hours", "custom"
                ]}},
                {"not": {"pattern": "^\\d+$"}},
                {"not": {"pattern": "^\\d{2}:\\d{2}$"}},
                {"not": {"pattern": "^\\d{4}-\\d{2}-\\d{2}$"}}
            ]
        },
        "dayAtom": {
            "oneOf": [
                {"type": "integer", "minimum": 1, "maximum": 31},
                {"$ref": "#/$defs/dayAtomWord"},
                {"$ref": "#/$defs/ordinalTuple"}
            ]
        },

        "direction": {"enum": ["prev", "next"]},
        "shift": {
            "oneOf": [
                {
                    "type": "array",
                    "prefixItems": [{"$ref": "#/$defs/direction"}, {"$ref": "#/$defs/dayAtom"}],
                    "minItems": 2,
                    "maxItems": 2,
                    "items": false
                },
                {
                    "type": "array",
                    "prefixItems": [{"$ref": "#/$defs/direction"}, {"const": "or_same"}, {"$ref": "#/$defs/dayAtom"}],
                    "minItems": 3,
                    "maxItems": 3,
                    "items": false
                }
            ]
        },

        "ifGuard": {
            "oneOf": [
                {
                    "type": "array",
                    "prefixItems": [{"$ref": "#/$defs/dayAtom"}],
                    "minItems": 1,
                    "maxItems": 1,
                    "items": false
                },
                {
                    "type": "array",
                    "prefixItems": [{"const": "not"}, {"$ref": "#/$defs/dayAtom"}],
                    "minItems": 2,
                    "maxItems": 2,
                    "items": false
                },
                {
                    "type": "array",
                    "prefixItems": [{"$ref": "#/$defs/direction"}, {"$ref": "#/$defs/dayAtom"}],
                    "minItems": 2,
                    "maxItems": 2,
                    "items": false
                },
                {
                    "type": "array",
                    "prefixItems": [{"$ref": "#/$defs/direction"}, {"const": "not"}, {"$ref": "#/$defs/dayAtom"}],
                    "minItems": 3,
                    "maxItems": 3,
                    "items": false
                }
            ]
        },

        "time": {"type": "string", "minLength": 5, "maxLength": 5, "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"},
        "timeOrEndOfDay": {"type": "string", "minLength": 5, "maxLength": 5, "pattern": "^(([01]\\d|2[0-3]):[0-5]\\d|24:00)$"},
        "window": {
            "type": "array",
            "prefixItems": [{"$ref": "#/$defs/time"}, {"$ref": "#/$defs/timeOrEndOfDay"}],
            "minItems": 2,
            "maxItems": 2,
            "items": false
        },

        "times": {
            "oneOf": [
                {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/time"}},
                {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["every"],
                    "properties": {
                        "every": {
                            "oneOf": [
                                {
                                    "type": "array",
                                    "prefixItems": [
                                        {"type": "integer", "minimum": 1, "maximum": 24},
                                        {"const": "hour"}
                                    ],
                                    "minItems": 2,
                                    "maxItems": 2,
                                    "items": false
                                },
                                {
                                    "type": "array",
                                    "prefixItems": [
                                        {"type": "integer", "minimum": 1, "maximum": 1440},
                                        {"const": "minute"}
                                    ],
                                    "minItems": 2,
                                    "maxItems": 2,
                                    "items": false
                                },
                                {
                                    "type": "array",
                                    "prefixItems": [
                                        {"type": "integer", "minimum": 1, "maximum": 86400},
                                        {"const": "second"}
                                    ],
                                    "minItems": 2,
                                    "maxItems": 2,
                                    "items": false
                                }
                            ]
                        },
                        "between": {
                            "oneOf": [
                                {"$ref": "#/$defs/window"},
                                {"const": "business_hour"}
                            ]
                        }
                    }
                }
            ]
        }
    }
}
